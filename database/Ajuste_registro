/*ATUALIZANDO OS STATUS DOS ANIMAIS*/
UPDATE animais
SET status = CASE
    WHEN id_animal IN (1,2,3) THEN 'ADOTADO'
    WHEN id_animal IN (4,5) THEN 'EM_PROCESSO'
    WHEN id_animal IN (6,7,8,9,10) THEN 'DISPONIVEL'
END
WHERE id_animal BETWEEN 1 AND 10;


/*ATUALIZANDO TABELA SOLICITACOES*/
UPDATE solicitacoes
SET status = CASE
    WHEN id_animal IN (1,2,3,4,5) THEN 'APROVADA'
    WHEN id_animal IN (6,7,8,9,10) THEN 'PENDENTE'
END
WHERE id_animal BETWEEN 1 AND 10;



