/*VALIDAÇÃO DOS DADOS APÓS AS ATUALIZAÇÕES*/

SELECT
    id_animal,
    nome,
    status
FROM animais
ORDER BY id_animal;

SELECT
    id_solicitacao,
    id_usuario,
    id_animal,
    status
FROM solicitacoes
ORDER BY id_animal;

SELECT
    a.id_adocao,
    u.nome AS adotante,
    an.nome AS animal,
    a.data_adocao
FROM adocoes a
INNER JOIN usuarios u
    ON a.id_usuario = u.id_usuario
INNER JOIN animais an
    ON a.id_animal = an.id_animal;