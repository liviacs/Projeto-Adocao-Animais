# ======================
# Servidor
# ======================
PORT=port
NODE_ENV=development

# ======================
# Banco de dados (PostgreSQL)
# ======================
DB_HOST=localhost
DB_PORT=
DB_NAME=
DB_USER=postgres
DB_PASSWORD=

# Ou use a connection string completa:
# DATABASE_URL=postgresql://usuario:senha@localhost:port/db_name

# ======================
# Autenticação (JWT)
# ======================
JWT_SECRET=troque_por_uma_chave_secreta_longa
JWT_EXPIRES_IN=7d

# ======================
# Recuperação de senha
# ======================
RESET_PASSWORD_SECRET=troque_por_outra_chave_secreta
RESET_PASSWORD_EXPIRES_IN=1h

# ======================
# Upload de arquivos (fotos dos animais)
# ======================
UPLOAD_DIR=uploads/
MAX_FILE_SIZE_MB=5

# Caso use serviço externo de armazenamento (ex: Cloudinary):
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ======================
# E-mail (notificações e recuperação de senha)
# ======================
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=
MAIL_USER=seu_email@exemplo.com
MAIL_PASSWORD=sua_senha_de_email
MAIL_FROM=noreply@adocao.com

# ======================
# Frontend (React)
# ======================
VITE_API_URL=http://localhost:port/api

# ======================
# Relatórios e PDF
# ======================
REPORTS_DIR=reports/

# ======================
# Logs
# ======================
LOG_LEVEL=info
LOG_DIR=logs/
